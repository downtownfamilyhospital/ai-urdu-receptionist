# =========================================================
#  SECRET KEYS — copy this file, rename to ".env", fill in
#  NEVER share this file or put it on the public internet
# =========================================================

# --- OpenAI (the AI brain + Whisper voice later) ---
OPENAI_API_KEY=sk-paste-your-openai-key-here

# --- Meta WhatsApp Cloud API (direct, cheapest) ---
WA_PHONE_NUMBER_ID=paste-your-phone-number-id-here
WA_ACCESS_TOKEN=paste-your-whatsapp-access-token-here

# --- Google Sheets (knowledge base) ---
# The whole service-account JSON, pasted as ONE line (see setup guide)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# The ID from your Google Sheet URL
GOOGLE_SHEET_ID=paste-your-sheet-id-here

# --- A password you invent, to protect the webhook ---
WEBHOOK_VERIFY_TOKEN=make-up-any-secret-word-here

# --- Port the server runs on (Railway sets this automatically) ---
PORT=3000
